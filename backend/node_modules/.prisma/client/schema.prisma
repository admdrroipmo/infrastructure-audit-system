generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model PsgcLocation {
  id        String         @id @default(cuid())
  psgcCode  String         @unique
  name      String
  type      String
  parentId  String?
  parent    PsgcLocation?  @relation("PsgcHierarchy", fields: [parentId], references: [id])
  children  PsgcLocation[] @relation("PsgcHierarchy")
  users     User[]
  buildings Building[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model User {
  id           String       @id @default(cuid())
  fullName     String
  email        String       @unique
  passwordHash String
  psgcId       String
  psgc         PsgcLocation @relation(fields: [psgcId], references: [id])
  accessLevel  String
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Building {
  id               String       @id @default(cuid())
  buildingName     String
  psgcId           String
  psgc             PsgcLocation @relation(fields: [psgcId], references: [id])
  assessmentStatus String
  latitude         Float?
  longitude        Float?
  address          String?
  form1            Form1?
  form2A           Form2A?
  form2B           Form2B?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Form1 {
  id         String   @id @default(cuid())
  buildingId String   @unique
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  data       Json
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Form2A {
  id         String   @id @default(cuid())
  buildingId String   @unique
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  data       Json
  score      Float
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Form2B {
  id               String   @id @default(cuid())
  buildingId       String   @unique
  building         Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  data             Json
  structuralScore  Float
  maintenanceScore Float
  finalStatus      String
  status           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model FormulaConfig {
  id                   String   @id @default(cuid())
  threshold            Float
  structuralWeights    Json
  maintenanceWeights   Json
  structuralThreshold  Float
  maintenanceThreshold Float
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
